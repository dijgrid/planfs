{
  "name": "planfs-vscode",
  "displayName": "PlanFS",
  "description": "Git-native project management for VS Code",
  "version": "0.7.0",
  "publisher": "dijgrid",
  "license": "MIT",
  "icon": "resources/icon.png",
  "preview": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/dijgrid/planfs.git",
    "directory": "src/vscode"
  },
  "homepage": "https://github.com/dijgrid/planfs#readme",
  "bugs": {
    "url": "https://github.com/dijgrid/planfs/issues"
  },
  "galleryBanner": {
    "color": "#0B1220",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "planfs",
    "planning",
    "project-management",
    "git",
    "tasks",
    "kanban",
    "roadmap",
    "markdown",
    "workflow",
    "developer-tools"
  ],
  "activationEvents": [
    "workspaceContains:.planfs",
    "onCommand:planfs.initializeRepository",
    "onCommand:planfs.openBoard",
    "onCommand:planfs.openInsights",
    "onCommand:planfs.createTask",
    "onCommand:planfs.createEpic",
    "onCommand:planfs.createMilestone",
    "onCommand:planfs.openTask",
    "onCommand:planfs.openEditor",
    "onCommand:planfs.applySavedFilter",
    "onCommand:planfs.clearSavedFilter",
    "onCommand:planfs.refreshExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "planfs.initializeRepository",
        "title": "PlanFS: Initialize Repository"
      },
      {
        "command": "planfs.openBoard",
        "title": "PlanFS: Open Board"
      },
      {
        "command": "planfs.openInsights",
        "title": "PlanFS: Open Insights"
      },
      {
        "command": "planfs.createTask",
        "title": "PlanFS: Create Task"
      },
      {
        "command": "planfs.createEpic",
        "title": "PlanFS: Create Epic"
      },
      {
        "command": "planfs.createMilestone",
        "title": "PlanFS: Create Milestone"
      },
      {
        "command": "planfs.openTask",
        "title": "PlanFS: Open Task"
      },
      {
        "command": "planfs.openEditor",
        "title": "PlanFS: Open Structured Editor"
      },
      {
        "command": "planfs.applySavedFilter",
        "title": "PlanFS: Apply Saved Filter"
      },
      {
        "command": "planfs.clearSavedFilter",
        "title": "PlanFS: Clear Saved Filter"
      },
      {
        "command": "planfs.refreshExplorer",
        "title": "PlanFS: Refresh Views"
      }
    ],
    "views": {
      "planfs-sidebar": [
        {
          "id": "planfs-explorer",
          "name": "PlanFS Explorer",
          "contextualTitle": "Project Planning"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "planfs.openEditor",
          "when": "view == planfs-explorer && viewItem =~ /^(task|epic|milestone)$/",
          "group": "inline"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "planfs-sidebar",
          "title": "PlanFS",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "vscode:prepublish": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "planfs-core": "0.7.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.16.0",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
