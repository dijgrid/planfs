{
  "name": "planfs-cli",
  "version": "0.5.0",
  "description": "Command-line interface for PlanFS",
  "main": "dist/index.js",
  "bin": {
    "planfs": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
